{
  "name": "rialto-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:api": "tsx watch src/server.ts",
    "dev:web": "npm run dev --prefix apps/web",
    "dev:all": "npm-run-all --parallel dev:api dev:web",
    "build": "tsc -p tsconfig.json",
    "build:web": "npm run build --prefix apps/web",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:agent:live": "RUN_LIVE_AGENT_EVALS=true vitest run src/agent/quote-comparison-live-smoke.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:web": "npm run typecheck --prefix apps/web"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.3.0",
    "@napi-rs/canvas": "^1.0.0",
    "@openai/agents": "^0.11.3",
    "exceljs": "^4.4.0",
    "fastify": "^5.6.2",
    "mammoth": "^1.11.0",
    "pdf-parse": "^2.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
